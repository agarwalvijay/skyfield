<?xml version="1.0" encoding="utf-8"?>
<!-- 4×1 banner. The android:text values are SAMPLE data: shown in the launcher's
     preview (previewLayout), overwritten at runtime by SkyfieldLarge.bind(). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:text="⛅" />

    <TextView
        android:id="@+id/widget_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:textColor="#FFD166"
        android:textSize="32sp"
        android:text="68°" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_place"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#F3F6FC"
            android:textStyle="bold"
            android:textSize="13sp"
            android:text="San Francisco" />

        <TextView
            android:id="@+id/widget_sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#CFE0F5"
            android:textSize="12sp"
            android:text="Partly Cloudy" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_hilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F3F6FC"
            android:textSize="13sp"
            android:text="H 72°  L 56°" />

        <TextView
            android:id="@+id/widget_windhum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="#D6E4F5"
            android:textSize="11sp"
            android:text="WSW 11 mph · 48%" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="#A8C0E0"
            android:textSize="10sp"
            android:text="8:30 AM" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:padding="6dp"
        android:text="⟳"
        android:textColor="#A8C0E0"
        android:textSize="18sp" />
</LinearLayout>
