<?xml version="1.0" encoding="utf-8"?>
<!-- 4×1 banner, RAIN state. The header (place · condition · H/L · ⟳) is pinned to
     the top, while the icon + temp are vertically centered in the FULL height so
     they land at exactly the same spot as the no-rain banner (which also centers
     them); the chart fills the space to their right. Symmetric vertical padding
     keeps that center == the widget center. Sample text is for the picker. -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:paddingHorizontal="14dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Header: place · condition · H/L  …  ⟳ (pinned top) -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_place"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#F3F6FC"
            android:textStyle="bold"
            android:textSize="13sp"
            android:text="San Francisco" />

        <TextView
            android:id="@+id/widget_sub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#CFE0F5"
            android:textSize="12sp"
            android:text="·  Light Rain" />

        <TextView
            android:id="@+id/widget_hilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F3F6FC"
            android:textSize="12sp"
            android:text="H 72°  L 56°" />

        <TextView
            android:id="@+id/widget_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:padding="4dp"
            android:text="⟳"
            android:textColor="#A8C0E0"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Icon + temp: left edge, centered within the chart's vertical band (just
         under the header → bottom). That sits a touch below the widget midline,
         giving breathing room under the header and aligning the temp with the
         bars. NOTE: can't use centerVertical+marginTop here — RelativeLayout's
         centerVertical ignores margins, so we anchor to the chart instead. -->
    <LinearLayout
        android:id="@+id/widget_tempblock"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_alignParentStart="true"
        android:layout_alignTop="@id/widget_chart"
        android:layout_alignBottom="@id/widget_chart"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Identical attrs to the no-rain banner's icon+temp so they render in
             the exact same spot (same 14dp left edge, size, and font metrics;
             centerVertical here == center_vertical there → same vertical center). -->
        <TextView
            android:id="@+id/widget_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:text="🌧️" />

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:textColor="#FFD166"
            android:textSize="32sp"
            android:text="68°" />
    </LinearLayout>

    <!-- Precip chart: to the right of the temp, stretched from just under the
         header down to the bottom edge so the bars use the full lower space
         (instead of floating centered with empty room beneath them). -->
    <ImageView
        android:id="@+id/widget_chart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_header"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/widget_tempblock"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:scaleType="fitXY"
        android:contentDescription="Next 2 hours precipitation" />
</RelativeLayout>
