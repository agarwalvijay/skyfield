{
  "name": "skyfield",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Skyfield — a modern, hyperlocal NWS/NOAA weather app",
  "author": "Atsumi Labs (https://atsumilabs.com)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
